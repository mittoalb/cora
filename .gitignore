# MkDocs site (built output + staged copy of CONTRIBUTING)
/site/
/docs/reference/contributing.md

# Hero source PNGs (regenerated via scripts/generate_hero_images.py).
# Only the .webp variants are served by the site and committed.
/docs/assets/*.png

# Claude Code per-project state (settings, scheduled tasks, hooks, etc.)
.claude/*
!.claude/CLAUDE.md
!.claude/agents/
!.claude/agents/**

# Talks (slidev decks): track sources, ignore build artifacts.
# Decks are built in CI by .github/workflows/docs.yml and mounted under
# /talks/<slug>/ on the docs site.
talks/*/node_modules/
talks/*/dist/
talks/*/*.pdf

# Mutmut working tree (regenerated per audit; holds the AST-mutated copy
# of src/ + tests/ under apps/api/mutants/). Never committed.
apps/api/mutants/
apps/api/mutmut-stats.json
